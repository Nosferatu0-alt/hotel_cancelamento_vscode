{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Pipeline Completo",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Pular EDA",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "args": ["--skip-eda"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "CSV customizado",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "args": ["--data", "data/hotel_bookings.csv"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    }
  ]
}
